---
---

<button class="search-toggle" aria-label="Search">
	<svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
		<path stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"
			d="M21 21l-4.35-4.35M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z"/>
	</svg>
</button>

<dialog class="search-dialog">
	<div class="search-container">
		<div id="search"></div>
	</div>
</dialog>

<style is:global>
	.search-toggle {
		background: none;
		border: none;
		cursor: pointer;
		color: rgb(var(--black));
		padding: 0.25em;
		line-height: 0;
	}
	.search-dialog {
		background: transparent;
		border: none;
		padding: 0;
		margin: 0;
		max-width: 100%;
		max-height: 100%;
		width: 100%;
		height: 100%;
		position: fixed;
		inset: 0;
	}
	.search-dialog::backdrop {
		background: rgba(0, 0, 0, 0.6);
	}
	.search-container {
		max-width: 600px;
		margin: 10vh auto 0;
		padding: 0 1em;
	}
	/* Pagefind UI overrides for neobrutalist theme */
	.pagefind-ui__search-input {
		font-family: inherit !important;
		font-size: 1em !important;
		border: 2px solid var(--border) !important;
		border-radius: 8px !important;
		box-shadow: var(--box-shadow) !important;
		background: var(--bg) !important;
		color: rgb(var(--gray-dark)) !important;
		padding: 0.6em 0.8em 0.6em 2.5em !important;
	}
	.pagefind-ui__search-input:focus {
		outline: none !important;
		border-color: var(--accent) !important;
	}
	.pagefind-ui__form::before {
		background-color: rgb(var(--gray)) !important;
		width: 20px !important;
		height: 20px !important;
		top: calc(20px * var(--pagefind-ui-scale)) !important;
		left: 14px !important;
		opacity: 1 !important;
	}
	.pagefind-ui__search-clear {
		background: transparent !important;
		color: rgb(var(--gray)) !important;
		border: none !important;
		font-size: 0 !important;
		width: 2em !important;
		height: 2em !important;
		padding: 0 !important;
		cursor: pointer !important;
		right: calc(38px * var(--pagefind-ui-scale)) !important;
		top: calc(14px * var(--pagefind-ui-scale)) !important;
	}
	.pagefind-ui__search-clear::before {
		content: "\00d7" !important;
		font-size: 1.5rem !important;
		line-height: 1 !important;
		color: rgb(var(--gray-dark)) !important;
	}
	.pagefind-ui__search-clear:hover::before {
		color: var(--accent) !important;
	}
	.pagefind-ui__results-area {
		margin-top: 1em !important;
	}
	.pagefind-ui__result {
		border: 2px solid var(--border) !important;
		border-radius: 8px !important;
		box-shadow: var(--box-shadow) !important;
		padding: 0.75em 1em !important;
		margin-bottom: 0.75em !important;
		background: var(--bg) !important;
	}
	.pagefind-ui__result-link {
		color: var(--accent) !important;
		font-weight: 700 !important;
	}
	.pagefind-ui__result-excerpt {
		color: rgb(var(--gray-dark)) !important;
		font-size: 0.9em !important;
	}
	mark.pagefind-ui__result-mark,
	.pagefind-ui__result-excerpt mark {
		background: var(--accent) !important;
		color: #fff !important;
		padding: 0.1em 0.2em !important;
		border-radius: 2px !important;
	}
	.pagefind-ui__message {
		color: rgb(var(--gray)) !important;
		font-family: inherit !important;
	}
	.pagefind-ui__button {
		background: var(--accent) !important;
		color: #fff !important;
		border: 2px solid var(--border) !important;
		border-radius: 8px !important;
		box-shadow: var(--box-shadow) !important;
		font-family: inherit !important;
		font-weight: 700 !important;
	}
</style>

<script is:inline>
	(function() {
		var toggle = document.querySelector('.search-toggle');
		var dialog = document.querySelector('.search-dialog');
		var initialized = false;

		async function openSearch() {
			dialog.showModal();

			if (!initialized) {
				initialized = true;
				await new Promise(function(resolve) {
					if (window.PagefindUI) { resolve(); return; }
					var script = document.createElement('script');
					script.src = '/pagefind/pagefind-ui.js';
					script.onload = resolve;
					script.onerror = function() {
						document.getElementById('search').innerHTML =
							'<p style="text-align:center;color:rgb(var(--gray))">Search is available on the built site.</p>';
						resolve();
					};
					document.head.appendChild(script);
				});
				if (window.PagefindUI) {
					new PagefindUI({
						element: '#search',
						showSubResults: true,
						showImages: false,
					});
				}
			}

			setTimeout(function() {
				var input = dialog.querySelector('.pagefind-ui__search-input');
				if (input) input.focus();
			}, 50);
		}

		toggle.addEventListener('click', openSearch);

		dialog.addEventListener('click', function(e) {
			if (e.target === dialog) dialog.close();
		});

		dialog.addEventListener('close', function() {
			toggle.focus();
		});

		document.addEventListener('keydown', function(e) {
			if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
				e.preventDefault();
				if (dialog.open) {
					dialog.close();
				} else {
					openSearch();
				}
			}
		});
	})();
</script>
