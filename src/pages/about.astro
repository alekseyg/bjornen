---
import { Image } from 'astro:assets';
import MeImage from '../assets/me.jpg';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About" description="Web developer, software engineer, habitual hiker, amateur chef." />
	</head>
	<body>
		<Header />
		<main>
			<div class="about">
				<div class="photo">
					<Image src={MeImage} alt="Aleksey Gladysh" />
				</div>
				<div class="bio">
					<h1>About</h1>
					<p>
						I'm Aleksey Gladysh — a software engineer specializing in web
						development. My friends and siblings call me a bear, so when I
						needed a domain, this felt like the right fit: <em>bjørnen</em> is
						"the bear" in Norwegian. Outside of work you'll find me on a trail
						or in the kitchen experimenting with whatever looked interesting at
						the market.
					</p>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: calc(100% - 2em);
		max-width: 720px;
	}
	.about {
		display: flex;
		flex-direction: column;
		gap: 2em;
	}
	.photo img {
		width: 100%;
		border-radius: 8px;
		box-shadow: var(--box-shadow);
	}
	@media (min-width: 640px) {
		.about {
			flex-direction: row;
			align-items: flex-start;
		}
		.photo {
			flex: 0 0 40%;
		}
		.bio {
			flex: 1;
		}
	}
	h1 {
		margin-top: 0;
	}
</style>
