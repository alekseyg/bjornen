---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
---

<html lang="en">
  <head>
    <BaseHead
      title="Virtual Keyboard Detection Demo - Blog"
      description="A demo of detecting virtual vs physical keyboards by measuring keydown/keyup timing."
    />
    <style is:global>
      main {
        margin-bottom: 120px;
      }

      #message-form {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: var(--bg);
        border-top: 2px solid var(--border);
        padding: 15px;
        box-shadow: var(--box-shadow);
      }

      .instructions {
        border: 2px solid var(--border);
        box-shadow: var(--box-shadow);
        border-radius: 8px;
        padding: 0.75em 1em;
        margin-bottom: 1.5em;
        font-size: 0.9em;
      }
      .instructions p {
        margin: 0;
      }
      .instructions p + p {
        margin-top: 0.5em;
      }

      .message {
        margin-bottom: 0.5em;
        padding: 0.5em 0.75em;
        background: rgb(var(--gray-light));
        border-radius: 8px;
        font-size: 0.9em;
        line-height: 1.4;
      }

      #message-form button {
        width: 100%;
        padding: 0.5em 1em;
        background: var(--accent);
        color: #fff;
        border: 2px solid var(--border);
        border-radius: 8px;
        box-shadow: var(--box-shadow);
        font-family: inherit;
        font-size: 1em;
        font-weight: 700;
        cursor: pointer;
        transition: translate 80ms, box-shadow 80ms;
      }

      #message-form button:hover {
        translate: 2px 2px;
        box-shadow: 2px 2px 0 var(--border);
      }

      #message-form button:active {
        translate: 4px 4px;
        box-shadow: none;
      }

      #message-form textarea {
        padding: 0.5em;
        border: 2px solid var(--border);
        background: var(--bg);
        color: rgb(var(--gray-dark));
        border-radius: 8px;
        font-family: inherit;
        font-size: 1em;
        resize: none;
        box-sizing: border-box;
        box-shadow: var(--box-shadow);
      }

      #message-form textarea:focus {
        outline: none;
        border-color: var(--accent);
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <p>Blog post: <a href="/blog/detecting-virtual-keyboards/">Detecting virtual keyboards</a></p>
      <div class="instructions">
        <p>Type in the box below and hit <kbd>Return</kbd></p>
        <p>
          On a physical keyboard, it should "send" the message,
          while on a virtual keyboard it should insert a newline.
        </p>
      </div>
      <div class="messages"></div>
    </main>
    <form id="message-form">
      <div>
        <textarea id="message_body" name="message[body]"></textarea>
      </div>
      <div>
        <button type="submit">Send</button>
      </div>
    </form>
    <script>
      import '../assets/virtual-keyboards.js'
    </script>
  </body>
</html>
