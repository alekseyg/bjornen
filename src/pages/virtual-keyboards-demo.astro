---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
---

<html lang="en">
  <head>
    <BaseHead
      title="Virtual Keyboard Detection Demo"
      description="A demo of detecting virtual vs physical keyboards by measuring keydown/keyup timing."
    />
    <style is:global>
      main {
        margin-bottom: 120px;
      }

      #message-form {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: var(--bg);
        border-top: 1px solid rgb(var(--gray-light));
        padding: 15px;
        box-shadow: var(--box-shadow);
      }

      .message {
        margin-bottom: 0.5em;
        padding: 0.5em 0.75em;
        background: rgb(var(--gray-light));
        border-radius: 8px;
        font-size: 0.9em;
        line-height: 1.4;
      }

      #message-form button {
        width: 100%;
        padding: 0.5em;
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 1em;
        cursor: pointer;
      }

      #message-form button:hover {
        background: var(--accent-dark);
      }

      #message-form textarea {
        padding: 0.5em;
        border: 1px solid rgb(var(--gray-light));
        border-radius: 8px;
        resize: none;
        box-sizing: border-box;
      }

      #message-form textarea:focus {
        outline: none;
        border-color: var(--accent);
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <p>Blog post: <a href="/blog/detecting-virtual-keyboards/">Detecting virtual keyboards</a></p>
      <div class="messages"></div>
    </main>
    <form id="message-form">
      <div>
        <textarea id="message_body" name="message[body]"></textarea>
      </div>
      <div>
        <button type="submit">Send</button>
      </div>
    </form>
    <script>
      import '../assets/virtual-keyboards.js'
    </script>
  </body>
</html>
